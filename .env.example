API_KEY=your_gemini_api_key_here
# Optional backwards-compatible alias:
# GEMINI_API_KEY=your_gemini_api_key_here

# Recommended for stable, secure signed sessions (set a long random string):
# FLASK_SECRET_KEY=replace_with_a_long_random_string

# --- Flask server (all optional) ---
# Enable the Werkzeug debugger ONLY for local development (never in production):
# FLASK_DEBUG=0
# Interface to bind. Defaults to localhost; use 0.0.0.0 to expose externally:
# FLASK_HOST=127.0.0.1
# FLASK_PORT=5001
# Comma-separated list of origins allowed to call the API (CORS):
# ALLOWED_ORIGINS=http://localhost:5001,http://127.0.0.1:5001
# Directory for server-side session files (keeps API keys off the client):
# SESSION_FILE_DIR=.flask_session
# Number of concurrent background review workers:
# REVIEW_WORKERS=2

# --- Models (optional overrides) ---
# GEMINI_MODEL=gemini-2.5-flash-lite
# EMBEDDING_MODEL=all-MiniLM-L6-v2
